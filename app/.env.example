# ==============================================================================
# VARIABLES DE ENTORNO COMPLETAMENTE OBLIGATORIAS
# ==============================================================================

# URL de conexión a la base de datos PostgreSQL (en Supabase, usa la cadena de conexión del Pooler)
# IMPORTANTE: Asegúrate de que empiece por 'postgresql://' (no 'postgres://') para evitar errores de SQLAlchemy.
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-ID]:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# URL pública de tu proyecto de Supabase (usada para validar tokens ES256 de forma asimétrica vía JWKS)
SUPABASE_URL=https://[YOUR-PROJECT-ID].supabase.co


# ==============================================================================
# VARIABLES CONDICIONALES / OPCIONALES DE AUTENTICACIÓN
# ==============================================================================

# Secreto JWT de Supabase.
# -> Si tu proyecto de Supabase es moderno y usa ES256 (firma asimétrica), puedes DEJAR ESTA VARIABLE VACÍA O ELIMINARLA. El backend validará los tokens usando llaves públicas mediante el JWKS de tu SUPABASE_URL.
# -> Si tu proyecto de Supabase es antiguo / usa HS256 (firma simétrica), coloca el JWT Secret aquí.
# Búscalo en: Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_JWT_SECRET=


# ==============================================================================
# CONFIGURACIÓN GENERAL DEL ENTORNO
# ==============================================================================

# Nombre de la aplicación (usado en la documentación interactiva Swagger/Redoc)
APP_NAME=Alza+

# Entorno de ejecución: 'development' para local, 'production' para despliegues como Render
APP_ENV=production

# Prefijo global para las rutas de la versión 1 de la API
API_V1_PREFIX=/api/v1


# ==============================================================================
# VARIABLES DE SUPABASE ADICIONALES (NO requeridas en Fase 1)
# ==============================================================================
SUPABASE_PUBLISHABLE_KEY=[YOUR-SUPABASE-PUBLISHABLE-KEY]
SUPABASE_SECRET_KEY=[YOUR-SUPABASE-SECRET-KEY]